<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>DataStory Report</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Georgia', serif; background: #0f0f11; color: #e8e6df; line-height: 1.7; }
  .header { padding: 3rem 4rem 2rem; border-bottom: 1px solid #2a2a2e; }
  .header h1 { font-size: 2rem; font-weight: 400; letter-spacing: -0.02em; color: #f5f3ec; }
  .header .meta { margin-top: .5rem; font-size: .85rem; color: #6b6964; font-family: 'Courier New', monospace; }
  .section { padding: 2.5rem 4rem; border-bottom: 1px solid #1e1e21; }
  .section h2 { font-size: 1.1rem; font-weight: 400; letter-spacing: .08em; text-transform: uppercase; color: #7c6f5e; margin-bottom: 1.5rem; }
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1rem; }
  .stat-card { background: #18181c; border: 1px solid #2a2a2e; border-radius: 8px; padding: 1.2rem; }
  .stat-card .val { font-size: 1.6rem; font-weight: 600; color: #c9a96e; font-family: 'Courier New', monospace; }
  .stat-card .label { font-size: .75rem; color: #5a5955; margin-top: .25rem; text-transform: uppercase; letter-spacing: .06em; }
  .anomaly-list { list-style: none; }
  .anomaly-list li { padding: .4rem 0; font-size: .875rem; color: #c17b4e; }
  .anomaly-list li::before { content: '⚠ '; }
  .story { background: #14141a; border-left: 3px solid #c9a96e; border-radius: 0 8px 8px 0; padding: 1.5rem 2rem; margin-bottom: 1.5rem; }
  .story h3 { font-size: 1.25rem; font-weight: 400; color: #f0ebe0; margin-bottom: .5rem; }
  .story .hook { font-style: italic; color: #9a9590; margin-bottom: 1rem; font-size: .95rem; }
  .story .narrative { font-size: .9rem; color: #ccc9c0; line-height: 1.8; }
  .story .score { font-size: .75rem; color: #5a5955; margin-top: .75rem; font-family: monospace; }
  .chart-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(580px, 1fr)); gap: 1.5rem; }
  .chart-wrap { background: #fff; border-radius: 8px; overflow: hidden; }
  .chart-meta { padding: .75rem 1rem; background: #18181c; }
  .chart-meta .chart-title { font-size: .875rem; color: #c9a96e; }
  .chart-meta .rationale { font-size: .75rem; color: #5a5955; margin-top: .2rem; }
  .footer { padding: 2rem 4rem; font-size: .75rem; color: #3d3d40; font-family: monospace; }
</style>
</head>
<body>

<div class="header">
  <h1>Data Story Report</h1>
  <div class="meta">
    {{ meta.row_count | int }} rows &nbsp;·&nbsp;
    {{ meta.column_count | int }} columns &nbsp;·&nbsp;
    domain: {{ meta.inferred_domain }} &nbsp;·&nbsp;
    {{ stories | length }} stories &nbsp;·&nbsp;
    {{ charts | length }} charts
  </div>
</div>

{% if stories %}
<div class="section">
  <h2>Key Narratives</h2>
  {% for story in stories %}
  <div class="story">
    <h3>{{ story.title }}</h3>
    <div class="hook">{{ story.hook }}</div>
    <div class="narrative">{{ story.narrative_text }}</div>
    <div class="score">impact score: {{ "%.2f"|format(story.score) }} &nbsp;·&nbsp; audience: {{ story.audience_mode }}</div>
  </div>
  {% endfor %}
</div>
{% endif %}

{% if charts %}
<div class="section">
  <h2>Visualizations</h2>
  <div class="chart-grid">
    {% for chart in charts %}
    <div>
      <div class="chart-meta">
        <div class="chart-title">{{ chart.title }}</div>
        <div class="rationale">{{ chart.rationale }}</div>
      </div>
      <div class="chart-wrap">{{ chart.rendered_html | safe }}</div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{% if meta.anomalies %}
<div class="section">
  <h2>Data Anomalies</h2>
  <ul class="anomaly-list">
    {% for a in meta.anomalies %}<li>{{ a }}</li>{% endfor %}
  </ul>
</div>
{% endif %}

<div class="section">
  <h2>Dataset Summary</h2>
  <div class="stats-grid">
    <div class="stat-card"><div class="val">{{ meta.row_count }}</div><div class="label">Rows</div></div>
    <div class="stat-card"><div class="val">{{ meta.column_count }}</div><div class="label">Columns</div></div>
    {% for col in meta.columns if col.mean is not none %}
    <div class="stat-card">
      <div class="val">{{ "%.2f"|format(col.mean) }}</div>
      <div class="label">{{ col.name }} avg</div>
    </div>
    {% endfor %}
  </div>
</div>

<div class="footer">Generated by DataStory · Powered by GPT-4 + Plotly</div>

</body>
</html>
